# Path to the SQLite database file.
# Local dev: leave blank — the app defaults to ../ksamata_funnels.db (repo root),
#   assuming process.cwd() is app/ (true for both `next dev` and `npx tsx` scripts).
# Production / Docker: set to an absolute path, e.g. /data/ksamata_funnels.db
FUNNELS_DB_PATH=

# ── Dokploy / Docker deployment ──────────────────────────────────────────────
# In Dokploy, set the following environment variable:
#   FUNNELS_DB_PATH=/data/ksamata_funnels.db
#
# Mount a persistent volume at /data inside the container.
# On first start the entrypoint script (docker-entrypoint.sh) automatically
# copies the baked-in seed DB to /data/ksamata_funnels.db if it does not
# already exist.  Subsequent restarts skip the copy — your data is preserved.
# ─────────────────────────────────────────────────────────────────────────────

# ── Optional HTTP Basic Auth (src/middleware.ts) ─────────────────────────────
# Leave blank to DISABLE auth (default — suitable behind a private network).
# Set to "user:password" to require Basic Auth on every page and API route.
#   ADMIN_BASIC_AUTH=admin:change-me
ADMIN_BASIC_AUTH=

# ── Kill-switch: turn auth OFF entirely (src/middleware.ts) ───────────────────
# Set to exactly "true" to disable auth EVERYWHERE — including production and
# even when ADMIN_BASIC_AUTH is set. Every page and API route becomes publicly
# reachable. Only "true" disables; any other value keeps auth on. Remove this
# variable to restore normal behaviour.
# WARNING: on a public URL this exposes the whole editor to anyone.
#   ADMIN_AUTH_DISABLED=true
ADMIN_AUTH_DISABLED=
