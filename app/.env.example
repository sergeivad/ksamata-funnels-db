# Path to the SQLite database file.
# Local dev: leave blank — the app defaults to ../ksamata_funnels.db (repo root),
#   assuming process.cwd() is app/ (true for both `next dev` and `npx tsx` scripts).
# Production / Docker: set to an absolute path, e.g. /data/ksamata_funnels.db
FUNNELS_DB_PATH=

# ── Dokploy / Docker deployment ──────────────────────────────────────────────
# In Dokploy, set the following environment variable:
#   FUNNELS_DB_PATH=/data/ksamata_funnels.db
#
# Mount a persistent volume at /data inside the container.
# On first start the entrypoint script (docker-entrypoint.sh) automatically
# copies the baked-in seed DB to /data/ksamata_funnels.db if it does not
# already exist.  Subsequent restarts skip the copy — your data is preserved.
# ─────────────────────────────────────────────────────────────────────────────
